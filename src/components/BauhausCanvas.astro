      width={180} height={180}
      bg="#003399"
      top="25%" left="48%"
      depth={0.04} zIndex={10}
      variant="circle"
      label="Education" labelColor="#FFCC00"
      revealTitle="LUISS Guido Carli" revealTitleColor="#FFCC00"
      revealBody="BSc AI &amp; Management<br>2024 — present<br>Roma, Italia<br><br>Target: HEC / ESSEC<br>Paris, 2027"
      revealColor="#fff"
      pulse
    />

    <!-- Competences -->
    <Shape
      width={200} height={120}
      bg="#C0392B"
      top="58%" left="10%"
      depth={0.06} zIndex={8}
      label="Competences"
      revealTitle="Technical + Political"
      revealBody="Python / ML / SNA<br>Astro / React / Git<br>EU policy / Con. law<br>Electoral systems"
    />

    <!-- Lingue -->
    <Shape
      width={140} height={140}
      bg="#FFCC00"
      top="8%" right="8%"
      depth={0.05} zIndex={9}
      variant="triangle"
      label="Lingue" labelColor="#003399" labelStyle="margin-top:40px"
      revealTitle="IT / EN / FR"
      revealBody="C2 / C2 / B2"
      revealColor="#003399"
      revealPadding="40px"
    />

    <!-- Interests -->
    <Shape
      width={130} height={130}
      border="2px solid #fff"
      top="45%" right="6%"
      depth={0.08} zIndex={7}
      variant="circle"
      label="Interests"
      revealTitle="Cinema / Music"
      revealBody="Art cinema<br>Cantautorato<br>Geopolitics<br>Editorial design"
    />

    <!-- Convictions -->
    <Shape
      width={240} height={60}
      border="2px solid #FFCC00"
      bottom="15%" left="28%"
      depth={0.03} zIndex={6}
      label="Convictions" labelColor="#FFCC00" labelStyle="font-size:11px;letter-spacing:3px"
      revealTitle="European federalist" revealTitleStyle="font-size:12px"
      revealBody="Fiscal union / Digital sovereignty / Open source / Nuclear for AI"
      revealColor="#FFCC00"
    />

    <!-- Projects -->
    <Shape
      width={260} height={150}
      border="2px solid #fff"
      bottom="8%" right="6%"
      depth={0.05} zIndex={7}
      label="Projects"
      revealTitle="Selected Work"
      revealBody="<a href='https://github.com/sakn0m/expert_ai_project_LUISS' target='_blank' rel='noopener'>Expert AI / NLP</a><br><a href='https://github.com/sakn0m/SNA_Project' target='_blank' rel='noopener'>SNA / Networks</a><br><a href='https://github.com/sakn0m/S-P500-Predictor' target='_blank' rel='noopener'>S&amp;P 500 / ML</a><br><a href='https://github.com/ariannacambi/AudienceDecode-317971' target='_blank' rel='noopener'>Audience Decode</a><br><a href='https://github.com/sakn0m' target='_blank' rel='noopener'>All projects →</a>"
    />

    <!-- Connect -->
    <Shape
      width={180} height={120}
      border="2px solid #C0392B"
      top="32%" left="4%"
      depth={0.04} zIndex={7}
      label="Connect" labelColor="#C0392B"
      revealTitle="Get in Touch"
      revealBody="<a href='https://github.com/sakn0m' target='_blank' rel='noopener'>GitHub</a> · <a href='https://www.linkedin.com/in/giorgio-vanini-8627123a4/' target='_blank' rel='noopener'>LinkedIn</a><br><a href='https://jojo.news' target='_blank' rel='noopener'>jojo.news</a><br><a href='mailto:giorgio@giorgiovanini.eu'>Email</a><br>Signal preferred"
      revealColor="#fff"
    />

    <!-- ═══ DECORATIVE ═══ -->
    <Shape width={30} height={30} bg="#C0392B" top="18%" left="36%" depth={0.09} zIndex={3} variant="circle" decorative />
    <Shape width={20} height={20} bg="#FFCC00" top="78%" left="55%" depth={0.07} zIndex={3} decorative rotate="45deg" />
    <Shape width={16} height={16} bg="#003399" top="42%" left="22%" depth={0.1} zIndex={3} variant="circle" decorative />
    <Shape width={12} height={12} bg="#fff" top="15%" left="65%" depth={0.06} zIndex={3} variant="circle" decorative />
    <Shape width={24} height={24} bg="#FFCC00" top="72%" left="4%" depth={0.08} zIndex={3} variant="circle" decorative />
    <div class="deco-line" style="top:50%;left:6%;transform:rotate(-15deg)"></div>
    <div class="deco-line" style="top:35%;right:20%;transform:rotate(30deg)"></div>

    <!-- Coordinate readout -->
    <div class="coords" id="coords">x: 0 / y: 0</div>
  </div>

  <!-- Mobile hint (outside screen so it stays fixed during pan) -->
  <div class="mobile-hint" id="mobile-hint">Drag to explore</div>
</div>

<style>
  .viewport {
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    position: relative;
    background: var(--ink);
  }

  .screen {
    position: relative;
    width: 100%;
    height: 100%;
    background: var(--ink);
    cursor: crosshair;
  }

  .floating-char {
    position: absolute;
    font-family: var(--font-display);
    font-weight: 800;
    color: rgba(255, 255, 255, 0.03);
    pointer-events: none;
    font-size: 200px;
    line-height: 1;
    z-index: 0;
  }

  .grid-line {
    position: absolute;
    background: var(--grid);
    pointer-events: none;
  }

  .grid-h {
    width: 100%;
    height: 1px;
  }

  .grid-v {
    height: 100%;
    width: 1px;
  }

  .diagonal {
    position: absolute;
    width: 200%;
    height: 1px;
    background: rgba(255, 255, 255, 0.03);
    transform-origin: 0 0;
    pointer-events: none;
  }

  .crosshair-h,
  .crosshair-v {
    position: absolute;
    background: var(--crosshair);
    pointer-events: none;
    z-index: 1;
    transition: all 0.08s linear;
  }

  .crosshair-h {
    height: 1px;
    width: 100%;
    left: 0;
  }

  .crosshair-v {
    width: 1px;
    height: 100%;
    top: 0;
  }

  .big-name {
    position: absolute;
    top: 40px;
    left: 40px;
    font-family: var(--font-display);
    font-size: 72px;
    font-weight: 800;
    color: #fff;
    line-height: 0.9;
    letter-spacing: -3px;
    pointer-events: none;
    z-index: 2;
    mix-blend-mode: difference;
  }

  .big-name .sub {
    display: block;
    font-size: 13px;
    font-weight: 400;
    font-family: var(--font-mono);
    letter-spacing: 4px;
    color: var(--mid-gray);
    margin-top: 12px;
    mix-blend-mode: normal;
  }

  .tag {
    position: absolute;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    pointer-events: none;
    white-space: nowrap;
  }

  .axis-label {
    position: absolute;
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    color: #333;
    text-transform: uppercase;
    pointer-events: none;
  }

  .corner-mark {
    position: absolute;
    font-family: var(--font-mono);
    font-size: 11px;
    color: #333;
    pointer-events: none;
  }

  .deco-line {
    position: absolute;
    width: 80px;
    height: 2px;
    background: #fff;
    pointer-events: none;
    opacity: 0.15;
  }

  .coords {
    position: absolute;
    bottom: 16px;
    right: 20px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: #444;
    z-index: 5;
    pointer-events: none;
  }

  .mobile-hint {
    display: none;
  }

  /* ═══ MOBILE: pannable canvas ═══ */
  @media (max-width: 768px) {
    .viewport {
      height: 100svh;
      touch-action: none;
    }

    .screen {
      position: absolute;
      width: 1100px;
      height: 850px;
      cursor: default;
      will-change: transform;
    }

    .crosshair-h,
    .crosshair-v,
    .coords {
      display: none;
    }

    .big-name {
      font-size: 56px;
    }

    .axis-label {
      display: none;
    }

    .mobile-hint {
      display: block;
      position: absolute;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 20;
      font-family: var(--font-display);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 3px;
      color: var(--dim-gray, #555);
      text-transform: uppercase;
      pointer-events: none;
      transition: opacity 1s ease;
    }
  }
</style>

<script>
  const viewport = document.getElementById('viewport')!;
  const screen = document.getElementById('screen')!;
  const ch = document.getElementById('ch')!;
  const cv = document.getElementById('cv')!;
  const coords = document.getElementById('coords')!;
  const bigName = screen.querySelector('.big-name') as HTMLElement;
  const shapes = screen.querySelectorAll<HTMLElement>('[data-depth]');
  const mobileHint = document.getElementById('mobile-hint');

  const isMobile = window.matchMedia('(max-width: 768px)').matches;

  if (isMobile) {
    /* ─── Mobile: pannable canvas + tap-to-reveal ─── */
    const CANVAS_W = 1100;
    const CANVAS_H = 850;

    let panX = 0, panY = 0;
    let startTouchX = 0, startTouchY = 0;
    let startPanX = 0, startPanY = 0;
    let velocityX = 0, velocityY = 0;
    let lastTouchX = 0, lastTouchY = 0;
    let lastTime = 0;
    let wasDrag = false;
    let inertiaFrame = 0;

    function clamp() {
      const vw = viewport.offsetWidth;
      const vh = viewport.offsetHeight;
      panX = Math.max(-(CANVAS_W - vw), Math.min(0, panX));
      panY = Math.max(-(CANVAS_H - vh), Math.min(0, panY));
    }

    function applyPan() {
      screen.style.transform = `translate3d(${panX}px,${panY}px,0)`;
    }

    // Start at top-left so the name is visible
    clamp();
    applyPan();

    viewport.addEventListener('touchstart', (e) => {
      cancelAnimationFrame(inertiaFrame);
      const t = e.touches[0];
      startTouchX = lastTouchX = t.clientX;
      startTouchY = lastTouchY = t.clientY;
      startPanX = panX;
      startPanY = panY;
      lastTime = Date.now();
      velocityX = velocityY = 0;
      wasDrag = false;
    }, { passive: true });

    viewport.addEventListener('touchmove', (e) => {
      e.preventDefault();
      const t = e.touches[0];
      const now = Date.now();
      const dt = now - lastTime || 16;

      const dx = t.clientX - startTouchX;
      const dy = t.clientY - startTouchY;

      if (!wasDrag && (Math.abs(dx) > 8 || Math.abs(dy) > 8)) {
        wasDrag = true;
        // Close any open shape when drag starts
        screen.querySelectorAll('.tap-active').forEach(s => s.classList.remove('tap-active'));
      }

      panX = startPanX + dx;
      panY = startPanY + dy;
      clamp();
      applyPan();

      // Track velocity for inertia (normalised to ~16ms frame)
      velocityX = ((t.clientX - lastTouchX) / dt) * 16;
      velocityY = ((t.clientY - lastTouchY) / dt) * 16;
      lastTouchX = t.clientX;
      lastTouchY = t.clientY;
      lastTime = now;
    }, { passive: false });

    viewport.addEventListener('touchend', () => {
      if (!wasDrag) return;
      function decelerate() {
        velocityX *= 0.92;
        velocityY *= 0.92;
        panX += velocityX;
        panY += velocityY;
        clamp();
        applyPan();
        if (Math.abs(velocityX) > 0.5 || Math.abs(velocityY) > 0.5) {
          inertiaFrame = requestAnimationFrame(decelerate);
        }
      }
      inertiaFrame = requestAnimationFrame(decelerate);
    });

    // Tap-to-reveal (delegated from screen)
    screen.addEventListener('click', (e) => {
      if (wasDrag) return;

      // Let links inside active shapes work
      const link = (e.target as HTMLElement).closest('a');
      if (link && link.closest('.tap-active')) return;

      const shape = (e.target as HTMLElement).closest('[data-depth]:not([style*="pointer-events:none"])') as HTMLElement | null;
      if (!shape) {
        screen.querySelectorAll('.tap-active').forEach(s => s.classList.remove('tap-active'));
        return;
      }

      const wasActive = shape.classList.contains('tap-active');
      screen.querySelectorAll('.tap-active').forEach(s => s.classList.remove('tap-active'));
      if (!wasActive) shape.classList.add('tap-active');
    });

    // Fade out the hint after a few seconds
    if (mobileHint) {
      setTimeout(() => { mobileHint.style.opacity = '0'; }, 3500);
    }

  } else {
    /* ─── Desktop: parallax + crosshair ─── */
    let mx = 0.5, my = 0.5;
    let animMx = 0.5, animMy = 0.5;

    screen.addEventListener('mousemove', (e) => {
      const rect = screen.getBoundingClientRect();
      mx = (e.clientX - rect.left) / rect.width;
      my = (e.clientY - rect.top) / rect.height;
      ch.style.top = (my * 100) + '%';
      cv.style.left = (mx * 100) + '%';
      coords.textContent = `x: ${Math.round(mx * rect.width)} / y: ${Math.round(my * rect.height)}`;
    });

    screen.addEventListener('mouseleave', () => {
      mx = 0.5;
      my = 0.5;
    });

    function animate() {
      animMx += (mx - animMx) * 0.08;
      animMy += (my - animMy) * 0.08;

      shapes.forEach((s) => {
        if (s === bigName) return;
        const depth = parseFloat(s.dataset.depth!) || 0;
        const dx = (animMx - 0.5) * depth * 600;
        const dy = (animMy - 0.5) * depth * 600;
        s.style.transform = `translate(${dx.toFixed(1)}px,${dy.toFixed(1)}px)`;
      });

      if (bigName) {
        const ndx = (animMx - 0.5) * 12;
        const ndy = (animMy - 0.5) * 12;
        bigName.style.transform = `translate(${ndx.toFixed(1)}px,${ndy.toFixed(1)}px)`;
      }

      requestAnimationFrame(animate);
    }
    animate();
  }
</script>
