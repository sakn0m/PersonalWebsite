---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'BSc AI & Management @ LUISS Guido Carli. AI · Data · Politics.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/icon.png" type="image/png" />
  <link rel="canonical" href={canonicalURL} />

  <title>{title}</title>
  <meta name="description" content={description} />

  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site)} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Giorgio Vanini",
    "url": "https://giorgiovanini.eu",
    "jobTitle": "AI & Management Student",
    "affiliation": {
      "@type": "Organization",
      "name": "LUISS Guido Carli"
    },
    "sameAs": [
      "https://www.linkedin.com/in/giorgio-vanini-8627123a4/",
      "https://github.com/sakn0m"
    ]
  })} />
</head>
<body>
  <slot />
</body>
</html>
