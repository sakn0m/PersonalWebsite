---
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = [
  {
    number: '01',
    title: 'Bombing Iran Won\'t Free It',
    tag: 'Geopolitica',
    date: 'March 2026',
    href: 'https://jojo.news/posts/1-bombing-iran-wont-free-it',
    external: true,
  },
];
---

<BaseLayout title="Blog — Giorgio Vanini" description="Articles on AI, European politics, and geopolitics.">
  <section class="blog-hero section-blue">
    <div class="container">
      <h1 class="blog-title">Writing</h1>
      <p class="blog-subtitle">
        Published on <a href="https://jojo.news" target="_blank" rel="noopener noreferrer" class="blog-link">jojo.news</a>
      </p>
    </div>
  </section>

  <section class="blog-list section-ink">
    <div class="container">
      <ol class="article-list">
        {articles.map(article => (
          <li class="article-item">
            <a
              href={article.href}
              target={article.external ? '_blank' : undefined}
              rel={article.external ? 'noopener noreferrer' : undefined}
              class="article-link"
            >
              <span class="article-number">{article.number}</span>
              <div class="article-info">
                <span class="article-title-text">{article.title}</span>
                <span class="article-meta">{article.tag} — {article.date}{article.external ? ' ↗' : ''}</span>
              </div>
              <span class="article-arrow">→</span>
            </a>
          </li>
        ))}
      </ol>

      <p class="blog-note">
        More articles at <a href="https://jojo.news" target="_blank" rel="noopener noreferrer" class="inline-link">jojo.news</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-hero {
    background-color: var(--eu-blue);
    padding: var(--space-xl) 0 var(--space-lg);
  }

  .blog-title {
    font-size: 4rem;
    text-transform: uppercase;
    color: var(--paper);
    margin-bottom: var(--space-xs);
  }

  .blog-subtitle {
    font-size: 1.125rem;
    color: var(--paper);
    opacity: 0.8;
  }

  .blog-link {
    font-weight: 700;
    border-bottom: 2px solid var(--gold);
  }

  .blog-list {
    padding: var(--space-xl) 0;
    min-height: 50vh;
  }

  .article-list {
    counter-reset: none;
  }

  .article-item {
    border-bottom: 1px solid rgba(245, 240, 232, 0.15);
  }

  .article-item:first-child {
    border-top: 1px solid rgba(245, 240, 232, 0.15);
  }

  .article-link {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) 0;
    transition: background-color 0.2s;
  }

  .article-link:hover {
    background-color: rgba(245, 240, 232, 0.04);
  }

  .article-number {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--eu-light);
    min-width: 4rem;
  }

  .article-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .article-title-text {
    font-family: var(--font-display);
    font-size: 1.5rem;
    text-transform: uppercase;
    color: var(--paper);
  }

  .article-meta {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.5;
  }

  .article-arrow {
    font-size: 1.5rem;
    opacity: 0.3;
    transition: opacity 0.2s, transform 0.2s;
  }

  .article-link:hover .article-arrow {
    opacity: 1;
    transform: translateX(4px);
  }

  .blog-note {
    margin-top: var(--space-lg);
    font-size: 0.875rem;
    opacity: 0.5;
  }

  .inline-link {
    color: var(--eu-light);
    font-weight: 700;
    border-bottom: 2px solid var(--eu-light);
    transition: border-color 0.2s;
  }

  .inline-link:hover {
    border-bottom-color: var(--gold);
  }

  @media (max-width: 768px) {
    .blog-title {
      font-size: 2.5rem;
    }

    .article-number {
      font-size: 2rem;
      min-width: 3rem;
    }

    .article-title-text {
      font-size: 1.125rem;
    }
  }
</style>
