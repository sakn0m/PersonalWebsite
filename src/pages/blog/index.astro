---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { articles } from '../../data/articles';
---

<BaseLayout title="Blog — Giorgio Vanini" description="Articles on AI, European politics, and geopolitics.">
  <section class="blog-hero">
    <div class="container">
      <h1 class="blog-title">Writing</h1>
    </div>
  </section>

  <section class="blog-list section-ink fade-up">
    <div class="container">
      <ol class="article-list">
        {articles.map(article => (
          <li class="article-item">
            <a
              href={article.href}
              target={article.external ? '_blank' : undefined}
              rel={article.external ? 'noopener noreferrer' : undefined}
              class="article-link"
            >
              <div class="article-info">
                <span class="article-title-text">{article.title}</span>
                {article.subtitle && <span class="article-subtitle">{article.subtitle}</span>}
                <span class="article-meta">{article.tag} / {article.date}{article.external ? ' ↗' : ''}</span>
              </div>
              <span class="article-arrow">&rarr;</span>
            </a>
          </li>
        ))}
      </ol>

    </div>
  </section>
</BaseLayout>

<style>
  .blog-hero {
    background-color: var(--eu-blue);
    padding: var(--space-xl) 0 var(--space-lg);
  }

  .blog-title {
    font-size: 4rem;
    text-transform: uppercase;
    color: var(--paper);
    margin-bottom: var(--space-xs);
    letter-spacing: -0.02em;
  }

  .blog-list {
    padding: var(--space-xl) 0;
    min-height: 50vh;
  }

  .article-list {
    counter-reset: none;
  }

  .article-item {
    border-bottom: 1px solid rgba(245, 240, 232, 0.12);
    border-left: 3px solid transparent;
    transition: border-color 0.15s;
  }

  .article-item:first-child {
    border-top: 1px solid rgba(245, 240, 232, 0.12);
  }

  .article-item:hover {
    border-left-color: var(--gold);
  }

  .article-link {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-sm) var(--space-md) var(--space-sm);
    transition: background-color 0.15s;
  }

  .article-link:hover {
    background-color: rgba(245, 240, 232, 0.03);
  }

  .article-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .article-title-text {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.5rem;
    text-transform: uppercase;
    color: var(--paper);
    letter-spacing: -0.01em;
  }

  .article-meta {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.4;
  }

  .article-subtitle {
    font-size: 0.8rem;
    opacity: 0.65;
    font-style: italic;
  }

  .article-arrow {
    font-size: 1.25rem;
    opacity: 0.2;
    transition: opacity 0.15s, transform 0.15s;
  }

  .article-link:hover .article-arrow {
    opacity: 1;
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .blog-title {
      font-size: 2.5rem;
    }

    .article-title-text {
      font-size: 1.1rem;
    }

    .article-item:hover {
      border-left-color: transparent;
    }

    .article-item.scroll-focus {
      border-left-color: var(--gold);
    }
  }
</style>

<script>
  if (window.matchMedia('(max-width: 768px)').matches) {
    const items = document.querySelectorAll('.article-item');
    let current = null;
    const update = () => {
      const center = window.innerHeight / 2;
      let closest = null;
      let minDist = Infinity;
      items.forEach((item) => {
        const rect = item.getBoundingClientRect();
        const itemCenter = rect.top + rect.height / 2;
        const dist = Math.abs(itemCenter - center);
        if (dist < minDist) { minDist = dist; closest = item; }
      });
      if (closest !== current) {
        current?.classList.remove('scroll-focus');
        closest?.classList.add('scroll-focus');
        current = closest;
      }
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }
</script>
